{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/contracts/privacy-remediation-tracker.schema.json",
  "title": "Foundation Privacy Remediation Tracker",
  "type": "object",
  "required": [
    "schemaVersion",
    "status",
    "mutationAuthority",
    "captureMode",
    "generatedAt",
    "input",
    "project",
    "privacyClaimPosture",
    "summary",
    "items",
    "warnings",
    "blockers",
    "recommendedRegistryUpdates"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "const": "proposal-only"
    },
    "mutationAuthority": {
      "type": "string",
      "const": "none"
    },
    "captureMode": {
      "type": "string",
      "enum": ["example", "operator-capture"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "input": {
      "type": "object",
      "required": ["path", "captureMode", "generatedAt"],
      "properties": {
        "path": { "type": "string" },
        "captureMode": {
          "type": "string",
          "enum": ["example", "operator-capture"]
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "project": {
      "type": "object",
      "required": ["slug", "name", "ownerRepo", "observedAt"],
      "properties": {
        "slug": { "type": "string" },
        "name": { "type": "string" },
        "ownerRepo": { "type": "string" },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "privacyClaimPosture": {
      "type": "string",
      "enum": ["unclaimed", "draft", "proved", "blocked"]
    },
    "summary": {
      "type": "string"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "findingClass",
          "severity",
          "affectedSurfaces",
          "ownerRepo",
          "remediationStatus",
          "proposedNextAction",
          "riskIfIgnored",
          "evidenceReference",
          "requiresFitnessOrSupabaseAction"
        ],
        "properties": {
          "findingClass": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["low", "moderate", "high", "critical"]
          },
          "affectedSurfaces": {
            "type": "array",
            "items": { "type": "string" }
          },
          "ownerRepo": { "type": "string" },
          "remediationStatus": {
            "type": "string",
            "enum": ["open", "planned", "in-progress", "blocked", "deferred", "resolved"]
          },
          "proposedNextAction": { "type": "string" },
          "riskIfIgnored": { "type": "string" },
          "evidenceReference": { "type": "string" },
          "requiresFitnessOrSupabaseAction": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "recommendedRegistryUpdates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "summary", "requiresApproval"],
        "properties": {
          "path": { "type": "string" },
          "summary": { "type": "string" },
          "requiresApproval": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
