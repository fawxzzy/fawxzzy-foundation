{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/contracts/proof-refresh-draft.schema.json",
  "title": "Foundation Proof Refresh Draft",
  "type": "object",
  "required": [
    "schemaVersion",
    "status",
    "mutationAuthority",
    "generatedAt",
    "sourceRegistry",
    "observationInput",
    "workflow",
    "summary",
    "projects"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "status": {
      "type": "string",
      "const": "proposal-only"
    },
    "mutationAuthority": {
      "type": "string",
      "const": "none"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "sourceRegistry": {
      "type": "object",
      "required": ["path", "updatedAt"],
      "properties": {
        "path": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "observationInput": {
      "type": "object",
      "required": ["mode"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["registry-only", "external-file"]
        },
        "path": {
          "type": "string"
        },
        "captureMode": {
          "type": "string",
          "enum": ["example", "operator-capture"]
        },
        "coverage": {
          "type": "string",
          "enum": ["partial", "full"]
        },
        "generatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "workflow": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "summary": {
      "type": "object",
      "required": [
        "totalProjects",
        "primaryDispositionCounts",
        "classificationCounts",
        "externalObservationProjects",
        "immutablePromotionProofProjects"
      ],
      "properties": {
        "totalProjects": {
          "type": "integer",
          "minimum": 0
        },
        "primaryDispositionCounts": {
          "type": "object",
          "required": [
            "unchanged-proof",
            "stale-proof",
            "provider-newer-than-registry",
            "provider-missing",
            "provider-conflict"
          ],
          "properties": {
            "unchanged-proof": { "type": "integer", "minimum": 0 },
            "stale-proof": { "type": "integer", "minimum": 0 },
            "provider-newer-than-registry": { "type": "integer", "minimum": 0 },
            "provider-missing": { "type": "integer", "minimum": 0 },
            "provider-conflict": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "classificationCounts": {
          "type": "object",
          "required": [
            "unchanged-proof",
            "stale-proof",
            "provider-newer-than-registry",
            "provider-missing",
            "provider-conflict",
            "accepted-private-source",
            "historical-mapping",
            "immutable-promotion-proof"
          ],
          "properties": {
            "unchanged-proof": { "type": "integer", "minimum": 0 },
            "stale-proof": { "type": "integer", "minimum": 0 },
            "provider-newer-than-registry": { "type": "integer", "minimum": 0 },
            "provider-missing": { "type": "integer", "minimum": 0 },
            "provider-conflict": { "type": "integer", "minimum": 0 },
            "accepted-private-source": { "type": "integer", "minimum": 0 },
            "historical-mapping": { "type": "integer", "minimum": 0 },
            "immutable-promotion-proof": { "type": "integer", "minimum": 0 }
          },
          "additionalProperties": false
        },
        "externalObservationProjects": {
          "type": "integer",
          "minimum": 0
        },
        "immutablePromotionProofProjects": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slug",
          "name",
          "observationMode",
          "primaryDisposition",
          "classifications",
          "observedAt",
          "proofCheckedAt",
          "immutablePromotionProof",
          "immutableFields",
          "conflictFields",
          "rationale",
          "proposedActions"
        ],
        "properties": {
          "slug": { "type": "string" },
          "name": { "type": "string" },
          "observationMode": {
            "type": "string",
            "enum": ["registry-only", "external-file"]
          },
          "primaryDisposition": {
            "type": "string",
            "enum": [
              "unchanged-proof",
              "stale-proof",
              "provider-newer-than-registry",
              "provider-missing",
              "provider-conflict"
            ]
          },
          "classifications": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "unchanged-proof",
                "stale-proof",
                "provider-newer-than-registry",
                "provider-missing",
                "provider-conflict",
                "accepted-private-source",
                "historical-mapping",
                "immutable-promotion-proof"
              ]
            },
            "uniqueItems": true
          },
          "observedAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "proofCheckedAt": {
            "type": "string",
            "format": "date-time"
          },
          "lastDeploymentProofAt": {
            "type": ["string", "null"],
            "format": "date-time"
          },
          "immutablePromotionProof": {
            "type": "boolean"
          },
          "immutableFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "conflictFields": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "rationale": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "proposedActions": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
