{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fawxzzy.dev/contracts/provider-capture.schema.json",
  "title": "Foundation Provider Capture Pack",
  "type": "object",
  "required": [
    "schemaVersion",
    "captureMode",
    "coverage",
    "generatedAt",
    "source"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "captureMode": {
      "type": "string",
      "enum": ["example", "operator-capture"]
    },
    "coverage": {
      "type": "string",
      "enum": ["partial", "full"]
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "source": {
      "type": "object",
      "required": ["label"],
      "properties": {
        "label": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "github": {
      "type": "object",
      "properties": {
        "repos": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/githubRepoCapture"
          }
        },
        "checks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/githubCheckCapture"
          }
        }
      },
      "additionalProperties": false
    },
    "vercel": {
      "type": "object",
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vercelProjectCapture"
          }
        },
        "deployments": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/vercelDeploymentCapture"
          }
        }
      },
      "additionalProperties": false
    },
    "supabase": {
      "type": "object",
      "properties": {
        "projects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/supabaseProjectCapture"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "captureBase": {
      "type": "object",
      "required": ["slug", "observedAt", "status"],
      "properties": {
        "slug": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "observedAt": {
          "type": "string",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "enum": [
            "verified",
            "ready",
            "missing",
            "not-found",
            "private-source",
            "historical",
            "tracked",
            "active",
            "not-applicable",
            "pending",
            "unknown"
          ]
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "githubRepoCapture": {
      "allOf": [
        {
          "$ref": "#/$defs/captureBase"
        },
        {
          "type": "object",
          "properties": {
            "exists": {
              "type": ["boolean", "null"]
            },
            "owner": {
              "type": "string"
            },
            "repo": {
              "type": "string"
            },
            "fullName": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "visibility": {
              "type": "string"
            },
            "defaultBranch": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "githubCheckCapture": {
      "allOf": [
        {
          "$ref": "#/$defs/captureBase"
        },
        {
          "type": "object",
          "properties": {
            "workflowName": {
              "type": "string"
            },
            "conclusion": {
              "type": "string"
            },
            "commitSha": {
              "type": "string"
            },
            "runId": {
              "type": "string"
            },
            "branch": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "vercelProjectCapture": {
      "allOf": [
        {
          "$ref": "#/$defs/captureBase"
        },
        {
          "type": "object",
          "properties": {
            "teamSlug": {
              "type": "string"
            },
            "projectNames": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "projectIds": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "vercelDeploymentCapture": {
      "allOf": [
        {
          "$ref": "#/$defs/captureBase"
        },
        {
          "type": "object",
          "properties": {
            "target": {
              "type": "string"
            },
            "projectName": {
              "type": "string"
            },
            "deploymentId": {
              "type": "string"
            },
            "alias": {
              "type": "string"
            },
            "githubCommitSha": {
              "type": "string"
            },
            "message": {
              "type": "string"
            },
            "gitDirty": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "supabaseProjectCapture": {
      "allOf": [
        {
          "$ref": "#/$defs/captureBase"
        },
        {
          "type": "object",
          "properties": {
            "projectRef": {
              "type": "string"
            },
            "projectName": {
              "type": "string"
            },
            "region": {
              "type": "string"
            },
            "postgresVersion": {
              "type": "string"
            },
            "organization": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
